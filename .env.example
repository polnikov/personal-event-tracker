# Copy to .env and edit
APP_SECRET_KEY=change-me-to-a-long-random-string-min-32-chars
APP_USERNAME=admin
# Generate hash: python -m app.cli hash-password
APP_PASSWORD_HASH=
DATABASE_URL=sqlite:///./data/events.db
TIMEZONE=Europe/Moscow
DEBUG=true
# Set to false when serving over HTTPS in production
COOKIE_SECURE=false

# Google Calendar sync (optional). Leave empty to disable the integration.
# Create an OAuth Web client in Google Cloud Console (Calendar API enabled).
# Redirect URI should match what's registered, e.g.
#   https://<your-domain>/api/google/oauth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# How often the background worker drains the outbox.
GOOGLE_SYNC_POLL_SECONDS=5
# After this many failures an outbox row marks its event as sync_status=failed.
GOOGLE_SYNC_FAIL_THRESHOLD=5
