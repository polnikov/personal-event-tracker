[Unit]
Description=Personal Event Tracker — backup timer (every 3 days)

[Timer]
# Every third day-of-month at 03:30 local Pi time.
OnCalendar=*-*-1/3 03:30:00
# Run on next boot if the Pi was off when the timer fired.
Persistent=true
Unit=event-tracker-backup.service

[Install]
WantedBy=timers.target
