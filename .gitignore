# ─── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
.Python
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
env/
ENV/

# Pytest / coverage / tooling
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Cygwin/MSYS bash crash dumps (Windows fork() failures)
*.stackdump
.tox/
.nox/
.mypy_cache/
.pyre/
.ruff_cache/

# ─── Secrets / runtime config ───────────────────────────────────────────────
.env
.env.*
!.env.example

# Local setup notes (paths, hostnames, references to secrets)
SETUP.md

# ─── Application data ───────────────────────────────────────────────────────
data/
*.db
*.db-journal
*.sqlite
*.sqlite3
*.sqlite3-journal

# Local backups produced by scripts/backup-db.sh
backups/

# ─── Node / frontend ────────────────────────────────────────────────────────
# Real deps live in web/node_modules; a root one is only ever stray vitest
# cache (.vite) from a command run in the wrong dir — ignore it too.
node_modules/
web/node_modules/
web/dist/
web/dist-ssr/
web/.vite/
web/coverage/
web/stats.html
web/*.local
*.tsbuildinfo

# TypeScript-compiled artifacts next to vite.config.ts (Vite reads .ts directly)
web/vite.config.js
web/vite.config.d.ts

# ─── Logs ───────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/

# ─── IDE / editor ───────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ─── OS / system ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ─── Misc ───────────────────────────────────────────────────────────────────
.specstory/
.claude/
google_credentials.json
